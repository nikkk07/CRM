# ============================================================
# We One Aviation — AI Attendance configuration
# Copy this file to ".env" and fill in your values.
# ============================================================

# --- CP Plus DVR/NVR connection (REQUIRED) ---
# The IP address of your DVR box on the WiFi/LAN network.
# Find it in the DVR menu: Main Menu > Network, or in your CP Plus mobile app.
DVR_HOST=192.168.1.108
DVR_PORT=554
DVR_USER=admin
DVR_PASS=your_dvr_password_here

# CP Plus uses the Dahua RTSP format (default below usually works as-is).
# subtype 0 = full quality main stream, 1 = lighter sub stream.
# RTSP_URL_TEMPLATE=rtsp://{user}:{password}@{host}:{port}/cam/realmonitor?channel={channel}&subtype={subtype}
# RTSP_SUBTYPE=0

# --- Attendance rules ---
EXIT_AFTER_MINUTES=60
# Face match strictness 0-1 (higher = stricter). 0.45 is a good default.
MATCH_THRESHOLD=0.45
# Analyze one frame per camera every N seconds.
PROCESS_EVERY_SEC=1.0

# --- Visitor tracking (unknown faces auto-tracked as anonymous visitors) ---
# When true, an unrecognized face gets full entry/exit tracking under
# role='visitor' and syncs to the CRM like students/employees. Their biometrics
# (face embeddings + images) auto-delete after VISITOR_RETENTION_DAYS; the
# anonymized "Visitor N" attendance log (times only) is kept.
# Set false to keep the old behavior (unknown faces only saved to the gallery).
VISITOR_TRACKING=true
# Minimum face height in pixels to auto-enroll a visitor (smaller = ignored).
VISITOR_MIN_FACE_PX=90
# Minimum detector confidence (0-1) to auto-enroll a visitor.
VISITOR_MIN_DET_SCORE=0.66
# Create a visitor only when the best match score is clearly below this
# (scores between this and MATCH_THRESHOLD are treated as "unsure", skipped).
VISITOR_NEW_THRESHOLD=0.32
# Days to retain visitor biometrics before the daily purge deletes them.
VISITOR_RETENTION_DAYS=7

# --- Groq (free tier) for the daily AI summary report (optional) ---
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# REPORT_HOUR=20

# --- Cloudflare R2 free tier: off-site backup of snapshots (optional) ---
# Create an R2 bucket + API token at dash.cloudflare.com -> R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- We One Aviation CRM (login + attendance auto-sync) ---
# The camera dashboard only lets CRM "Admin" department members sign in.
# CRM_API_URL is your deployed CRM backend.
CRM_API_URL=https://crm-weoneaviation.onrender.com
# Attendance is pushed to the CRM automatically. The token below must match
# ATTENDANCE_INGEST_TOKEN in the CRM backend's environment.
CRM_WEBHOOK_URL=https://crm-weoneaviation.onrender.com/api/attendance/ingest
CRM_WEBHOOK_TOKEN=

# --- Web dashboard ---
PORT=8100
